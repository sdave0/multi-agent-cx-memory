# MindCX Environment Variables Example
# Copy this to .env and fill in your actual keys.

# LLM Providers (At least one required based on llm_config.yaml)
GEMINI_API_KEY=your_gemini_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here
OPENAI_API_KEY=your_openai_api_key_here

# Redis (Used for session tracking and escalation queue)
REDIS_URL=redis://localhost:6379

# Database (Used for accounts and semantic memory)
DATABASE_URL=sqlite:///./mindcx.db

# Observability (Optional, for Langfuse tracing)
LANGFUSE_SECRET_KEY=your_langfuse_secret_key
LANGFUSE_PUBLIC_KEY=your_langfuse_public_key
LANGFUSE_BASE_URL=https://us.cloud.langfuse.com

# Gateway Security (Optional secret for protected API routes)
API_KEY=mindcx_dev_secret_2026
JWT_SECRET_KEY=mindcx_super_secret_key_2026
