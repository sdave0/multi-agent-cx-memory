# 🚀 MindCX - Master Environment Configuration
# Copy this to .env and fill in your actual values.

# ---------------------------------------------------------
# 1. LLM PROVIDERS (At least one required)
# ---------------------------------------------------------
# Default provider is set in backend/config/llm_config.yaml
GEMINI_API_KEY=your_gemini_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here
OPENAI_API_KEY=your_openai_api_key_here

# ---------------------------------------------------------
# 2. EVALUATION & BENCHMARKING
# ---------------------------------------------------------
# 'mock' (default): Runs tests/evals with zero token cost using simulated responses.
# 'live': Runs against real LLM endpoints for true performance/cost telemetry.
EVAL_MODE=mock

# ---------------------------------------------------------
# 3. CORE INFRASTRUCTURE
# ---------------------------------------------------------
# Redis: Used for session tracking, state notes, and escalation queues.
REDIS_URL=redis://localhost:6379

# Database: SQLite with Vector support for accounts and semantic memory.
DATABASE_URL=sqlite:///./mindcx.db

# ---------------------------------------------------------
# 4. OBSERVABILITY (Optional)
# ---------------------------------------------------------
# Tracks every trace, cost, and latency in the Langfuse dashboard.
LANGFUSE_SECRET_KEY=
LANGFUSE_PUBLIC_KEY=
LANGFUSE_BASE_URL=https://us.cloud.langfuse.com

# ---------------------------------------------------------
# 5. SECURITY & AUTHENTICATION
# ---------------------------------------------------------
# Secrets for JWT signing and protected REST routes.
# CHANGE THESE FOR PRODUCTION!
API_KEY=mindcx_dev_secret_2026
JWT_SECRET_KEY=mindcx_super_secret_key_2026
